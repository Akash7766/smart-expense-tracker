# Server (Render sets PORT automatically)
PORT=5001
NODE_ENV=development

# MongoDB — use Atlas or another cloud URI in production
MONGO_URI=mongodb://127.0.0.1:27017/expenseDB

# Firebase Admin (same Firebase project as the frontend Web app).
# Production (Render): use B — no JSON file on disk required.

# A) Local file — resolved without process.cwd()
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# B) Hosted (recommended on Render/Railway): paste minified one-line JSON as the variable value
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# C) Absolute path to key file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# AI Provider (optional — insights fallback works without it)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — comma-separated browser origins (required for browser clients). No defaults in code.
# Include dev (5173), production preview (4173/4174), and deployed frontend:
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:4174,http://127.0.0.1:4174,https://your-frontend.onrender.com

# Optional legacy: merged into the same allowlist (comma-separated allowed)
# FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
