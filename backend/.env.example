# Required everywhere
MONGO_URI=

# Production (NODE_ENV=production) — all required
NODE_ENV=development
PORT=5001
# Render sets PORT automatically; omit in .env on the platform.

# Firebase Admin — production: single-line JSON only (file paths ignored in production)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Local dev only (ignored when NODE_ENV=production):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=

# CORS — comma-separated browser origins (required in production, at least one)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.onrender.com

# AI (optional)
GEMINI_API_KEY=
# OPENAI_API_KEY=

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
