# Backend API — prefer VITE_API_URL (origin only or full .../api base).
# If the value does not end with /api, /api is appended for Express routes under /api.
VITE_API_URL=http://localhost:5001

# Production bundle (`vite build`) reads `.env.production`. To test that bundle locally against
# your Express API + avoid CORS/port surprises, use: npm run preview:local (uses `.env.preview-local`).

# Legacy alias (still supported):
# VITE_API_BASE_URL=http://localhost:5001/api

# Firebase Web SDK — from Firebase Console → Project settings → Your apps
# Replace YOUR_* placeholders with firebaseConfig values; do not wrap in quotes.
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
